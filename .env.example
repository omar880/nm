# انسخ هذا الملف وسمّه .env.local للتجربة محليًا (vercel dev)
# على السيرفر الحقيقي، ضيف هذا المتغير من لوحة تحكم Vercel:
# Project Settings → Environment Variables → ANTHROPIC_API_KEY
# احصل على المفتاح من: https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
